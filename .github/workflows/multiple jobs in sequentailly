name: multiple workflows in serial

on:
  workflow_dispatch:

jobs:
  build:
    name: build the code
    runs-on: ubuntu-latest
    steps:
      - name: build
        run: echo "build"

  test:
    name: test the code
    needs: build
    runs-on: ubuntu-latest
    steps:
      - name: test
        run: echo "test"

  deploy:
    name: deploy the code
    needs: test
    runs-on: ubuntu-latest
    steps:
      - name: deploy
        run: echo "deploy"   
